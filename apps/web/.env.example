# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Sanity CMS ─────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Solana ─────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_XP_MINT_ADDRESS=
NEXT_PUBLIC_BACKEND_SIGNER=

# ─── Helius ─────────────────────────────────────────────────
# Same API key as in RPC URL; used server-side for webhook mgmt + DAS API
NEXT_PUBLIC_HELIUS_API_KEY=
# Secret shared with Helius webhook for auth header validation
HELIUS_WEBHOOK_SECRET=
# (Optional) Webhook ID — set after registerWebhook() for updates
HELIUS_WEBHOOK_ID=

# ─── Analytics (optional) ──────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=

# ─── Auth ───────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Build Server ──────────────────────────────────────────
NEXT_PUBLIC_BUILD_SERVER_URL=
BUILD_SERVER_API_KEY=

# ─── Admin (server-only — NEVER expose to browser) ────────
PROGRAM_AUTHORITY_SECRET=
BACKEND_SIGNER_SECRET=
ADMIN_SECRET=
SANITY_ADMIN_TOKEN=

# ─── App URL (sitemap, OG tags, metadata URIs) ────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
